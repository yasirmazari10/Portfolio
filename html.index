      <div class="gallery-item-inner">📦<span style="font-size:.85rem;color:var(--text2)">Inventory Map</span></div>
      <div class="gallery-item-overlay"><h4>Warehouse Heatmap</h4><p>Python · Plotly · 5,000 SKUs</p></div>
    </div>
    <div class="gallery-item reveal" style="transition-delay:.1s" data-cat="ai">
      <div class="gallery-item-inner">🔬<span style="font-size:.85rem;color:var(--text2)">NLP Pipeline</span></div>
      <div class="gallery-item-overlay"><h4>Sentiment Analysis Flow</h4><p>BERT · HuggingFace</p></div>
    </div>
    <div class="gallery-item reveal" style="transition-delay:.18s" data-cat="analytics">
      <div class="gallery-item-inner">📉<span style="font-size:.85rem;color:var(--text2)">Churn Analytics</span></div>
      <div class="gallery-item-overlay"><h4>Churn Risk Dashboard</h4><p>XGBoost · SHAP Values</p></div>
    </div>
  </div>
</section>

<!-- ══════════════════ CONTACT ══════════════════ -->
<section id="contact" aria-label="Contact">
  <div class="reveal" style="text-align:center;margin-bottom:3rem">
    <div class="section-tag">Contact</div>
    <h2 class="section-title">Let's <span class="gradient-text">Connect</span></h2>
    <p class="section-sub" style="margin:0 auto">Have a project in mind or want to discuss data challenges? Reach out — I'd love to hear from you.</p>
  </div>
  <div class="contact-grid">
    <div class="reveal">
      <div class="contact-item">
        <div class="contact-icon ci1"><i class="fas fa-envelope"></i></div>
        <div><h4>Email</h4><p>alex.morgan@email.com</p></div>
      </div>
      <div class="contact-item">
        <div class="contact-icon ci2"><i class="fab fa-linkedin"></i></div>
        <div><h4>LinkedIn</h4><p>linkedin.com/in/alexmorgan-data</p></div>
      </div>
      <div class="contact-item">
        <div class="contact-icon ci3"><i class="fab fa-github"></i></div>
        <div><h4>GitHub</h4><p>github.com/alexmorgan-ai</p></div>
      </div>
      <div class="contact-item">
        <div class="contact-icon" style="background:linear-gradient(135deg,#ff9a3c,#ff4d8d)"><i class="fas fa-map-marker-alt"></i></div>
        <div><h4>Location</h4><p>New York, NY · Open to Remote</p></div>
      </div>
    </div>
    <div class="reveal" style="transition-delay:.15s">
      <div id="contactForm">
        <div class="form-row">
          <div class="form-group">
            <input type="text" id="fname" placeholder=" " aria-label="First name" />
            <label for="fname">First Name</label>
          </div>
          <div class="form-group">
            <input type="text" id="lname" placeholder=" " aria-label="Last name" />
            <label for="lname">Last Name</label>
          </div>
        </div>
        <div class="form-group">
          <input type="email" id="cemail" placeholder=" " aria-label="Email address" />
          <label for="cemail">Email Address</label>
        </div>
        <div class="form-group">
          <input type="text" id="subject" placeholder=" " aria-label="Subject" />
          <label for="subject">Subject</label>
        </div>
        <div class="form-group">
          <textarea id="message" placeholder=" " aria-label="Message"></textarea>
          <label for="message">Message</label>
        </div>
        <button class="submit-btn" onclick="handleSubmit()" type="button">
          <i class="fas fa-paper-plane"></i> Send Message
        </button>
      </div>
      <div class="form-success" id="formSuccess">
        <i class="fas fa-check-circle"></i>
        <strong>Message Sent!</strong><br>
        <span style="font-size:.9rem;color:var(--text2)">Thanks for reaching out. I'll get back to you within 24 hours.</span>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════ FOOTER ══════════════════ -->
<footer>
  <div class="footer-logo">Alex Morgan</div>
  <p style="color:var(--text2);font-size:.9rem;max-width:420px;margin:0 auto .5rem">
    Turning data into decisions. Building AI that matters.
  </p>
